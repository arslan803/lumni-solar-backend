# Production — set these in Railway Dashboard → Variables

DATABASE_URL=postgresql://user:password@host:5432/lumni?schema=public
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
JWT_EXPIRES_IN=7d
PORT=4000

# Comma-separated if you have www + non-www
FRONTEND_URL=https://lumni.pk,https://www.lumni.pk

STORAGE_URL=https://storage.lumni.pk
REDIS_URL=redis://default:password@host:6379

# JazzCash live
JAZZCASH_MERCHANT_ID=YOUR_MERCHANT_ID
JAZZCASH_PASSWORD=YOUR_PASSWORD
JAZZCASH_INTEGRITY_SALT=YOUR_SALT
JAZZCASH_RETURN_URL=https://lumni.pk/app/customer/bookings
JAZZCASH_IPN_URL=https://api.lumni.pk/api/jazzcash/ipn
JAZZCASH_SANDBOX=false

PILOT_CITY=Lahore
PLATFORM_COMMISSION_PCT=6
